# ============================================================
# SOURCES — Datos crudos reorganizados
# ============================================================

# MIDAGRI: Excel pesado — excluir
sources/midagri/*.xlsx

# INDECI: Shapefiles y Excel pesados — excluir
sources/indeci/shapefiles/
sources/indeci/resumenes/*.xlsx

# NASA POWER CRUDO — excluir (muy pesado)
sources/nasa/nasapowercrudo/

# NASA POWER PROCESADO — solo subir 5 CSVs de muestra
sources/nasa/nasapower/
!sources/nasa/nasapower/PIURA-PIURA.csv
!sources/nasa/nasapower/PIURA-SULLANA.csv
!sources/nasa/nasapower/LA LIBERTAD-VIRU.csv
!sources/nasa/nasapower/ICA-ICA.csv
!sources/nasa/nasapower/LAMBAYEQUE-LAMBAYEQUE.csv

# NASA proceso data engineering — incluir todo (son reportes y CSVs procesados)
# sources/nasa/proceso-data-engineering-nasa/ -> se sube completo

# AGRARIA.PE — incluir CSVs de noticias (son ligeros)
# sources/agraria-pe/ -> se sube completo

# ============================================================
# PIPELINE OUTPUT — incluir todo excepto archivos muy pesados
# ============================================================

# CSVs grandes del pipeline (>5MB) — excluir
pipeline/output/09_etl/master_dataset_fase1.csv
pipeline/output/09_etl/master_dataset_raw_values.csv
pipeline/output/02_lectura/nasa_long_raw.csv
pipeline/output/05_limpieza/nasa_long_clean.csv
pipeline/output/05_limpieza/agraria_noticias_clean.csv
pipeline/output/05_limpieza/indeci_eventos_clean.csv

# El resto del pipeline se sube (notebooks, graficos, CSVs pequeños)

