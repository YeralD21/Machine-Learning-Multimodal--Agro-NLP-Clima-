# Data Files (Avoid pushing heavy raw data to GitHub)
data/raw/*
data/interim/*
data/processed/*
data/external/*
data/01_raw/*
data/02_interim/*
data/03_processed/*
data/04_reports/*

# Allow specific data folders requested
!data/interim/indeci/
!data/interim/metadata/
!data/interim/midagri/
!data/interim/nasa/
!data/raw/agraria_pe/
!data/interim/agraria/
!data/processed/trend_check.png
!models/scalers/scaler_fase1.pkl
!models/scalers/scaler_fase2_nlp.pkl
!data/interim/agraria/noticias_con_sentimiento.csv

# Ensure .gitkeep files are still tracked
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/master_dataset_lstm.csv
!data/processed/master_dataset_fase1.csv
!data/processed/dataset_fase2_multivariado.csv
!data/03_processed/master_dataset_fase1_v2.csv
!data/04_reports/*.png
!data/04_reports/*.txt
!database/
!models/scalers/scaler_fase1_v2.pkl
!data/external/.gitkeep

